
# Chatwoot AI Agent Bot Configuration
# ==========================================

# ── Chatwoot ──────────────────────────────────────────────────
# Base URL of your Chatwoot instance (no trailing slash)
CHATWOOT_BASE_URL=http://localhost:3000

# Chatwoot Agent Bot Access Token
CHATWOOT_API_TOKEN=your_agent_bot_access_token

# Chatwoot numeric account ID
CHATWOOT_ACCOUNT_ID=1

# ── AI Agent (LiteLLM) ─────────────────────────────────────────
# Model name to use. 
# For Ollama: ollama/qwen:3.50.8b
# For OpenAI: gpt-4o
# For Anthropic: claude-3-5-sonnet-20240620
LLM_MODEL=ollama/qwen:3.50.8b

# API Base URL (required for local models like Ollama)
LLM_API_BASE=http://localhost:11434

# API Key (required for OpenAI, Anthropic, etc. Leave empty for local Ollama without auth)
LLM_API_KEY=

# Max conversation turns to keep in memory per chat
AI_MAX_HISTORY=20

# System prompt
AI_SYSTEM_PROMPT="You are a helpful support assistant. Be concise, friendly, and answer in the same language the user writes to you."

# ── Server ────────────────────────────────────────────────────
# Host to bind the webhook server (0.0.0.0 to listen on all interfaces)
SERVER_HOST=0.0.0.0

# Port for the webhook server
SERVER_PORT=8000

# Shared secret for Chatwoot webhook validation (optional but recommended)
# Found in Chatwoot -> Settings -> Integrations -> Webhooks
WEBHOOK_SECRET=


# Logging
# ------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Calendar Integration ──────────────────────────────────────
# Set to true to use Google Calendar API, or false to use Cal.com API
USE_GOOGLE_CALENDAR=false

# ── SMTP (Email Notifications) ────────────────────────────────
# SMTP Host (e.g. smtp.gmail.com)
SMTP_HOST=
# SMTP Port (usually 587 for TLS, or 465 for SSL)
SMTP_PORT=587
# SMTP Username
SMTP_USERNAME=
# SMTP Password (for Gmail, use an App Password)
SMTP_PASSWORD=
# SMTP Sender Email (default same as Username if empty)
SMTP_FROM_EMAIL=
# Main Mailbox to receive lead details and conversation history
NOTIFICATION_EMAIL=
