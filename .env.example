# ============================================================
#  Chatwoot <-> Telegram Bridge — Environment Variables
#  Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------------
# Telegram Bot
# ------------------------------------------------------------------
# Get this from @BotFather on Telegram after creating a new bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------------------------------------------
# Chatwoot Instance
# ------------------------------------------------------------------
# Base URL of your self-hosted Chatwoot (no trailing slash).
CHATWOOT_BASE_URL=http://localhost:3000

# Personal Access Token: Chatwoot → Profile Settings → Access Token
CHATWOOT_API_TOKEN=your_chatwoot_api_token_here

# Numeric Account ID visible in the Chatwoot URL: /app/accounts/<ID>/...
CHATWOOT_ACCOUNT_ID=1

# Numeric Inbox ID for the API-type inbox you created for this bot.
# Chatwoot → Settings → Inboxes → (your inbox) → Settings → ID in URL.
CHATWOOT_INBOX_ID=1

# ------------------------------------------------------------------
# Webhook Server
# ------------------------------------------------------------------
# Host and port the FastAPI server listens on.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Optional shared secret to authenticate calls from Chatwoot.
# Set the same value in Chatwoot → Settings → Integrations → Webhooks.
# Leave blank to disable signature verification (not recommended for production).
WEBHOOK_SECRET=

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Path to the SQLite database file (relative to project root).
DATABASE_PATH=bridge.db

# ------------------------------------------------------------------
# AI Agent (Ollama)
# ------------------------------------------------------------------
# Enable automatic AI responses via a local Ollama instance.
AI_ENABLED=false

# URL of your Ollama server (default: localhost:11434).
# If Ollama runs on a different host, change the URL accordingly.
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use (e.g. llama3, mistral, gemma, phi).
# Make sure the model is pulled beforehand:  ollama pull llama3
OLLAMA_MODEL=llama3

# System prompt that defines the AI's behavior and personality.
AI_SYSTEM_PROMPT="You are a helpful support assistant. Be concise, friendly, and answer in the same language the user writes to you."

# Number of conversation turns (user+assistant pairs) to keep in memory.
AI_MAX_HISTORY=20

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
